---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

type Category = {
  _id: string;
  name: string;
  slug: string;
};

const categoryIcons: Record<string, string> = {
  "photo-editing": "🖼️",
  "video-editing": "🎬",
  "audio-editing": "🎧",
  "thumbnail-tools": "🧩",
  "ai-tools": "🤖",
};

const categories: Category[] = await sanityClient.fetch(`
  *[_type == "category"]{
    _id,
    name,
    "slug": slug.current
  }
`);
---

<Layout>

<!-- HERO -->

<section class="relative pt-28 pb-36 overflow-hidden">

<div class="hero-light top-[-250px] left-[20%]"></div>
<div class="hero-light bottom-[-300px] right-[10%] opacity-50"></div>

<div class="max-w-6xl mx-auto grid md:grid-cols-[240px_1fr] gap-8 items-center">

<div class="flex justify-center md:justify-end">

<div class="hero-avatar">

<img src="/hero.png" alt="Creator tools">

</div>

</div>

<div>

<h1 class="text-6xl md:text-7xl font-bold leading-[1.05] text-white">

Mana.Core  
<span class="gradient-text">Tools</span>

</h1>

<p class="mt-6 text-xl text-slate-300">

Stop searching. Just use Mana.core.

</p>

<p class="mt-4 text-slate-400 text-lg max-w-xl">

Discover the best free tools for creators, editors, and builders — all curated in one place.

</p>

<div class="mt-10 flex flex-wrap gap-4">

<a href="#categories" class="btn-ai">

Explore Categories

</a>

<a href="#" class="px-6 py-3 rounded-xl border border-white/10 text-slate-200 hover:bg-white/5 transition">

Browse Tools

</a>

</div>

</div>

</div>

</section>

<!-- CATEGORIES -->

<section id="categories" class="pb-36">

<div class="max-w-6xl mx-auto">

<h2 class="text-4xl font-bold text-white mb-3">

Categories

</h2>

<p class="text-slate-400 mb-16 max-w-xl">

Explore curated tools organized by creator workflows.

</p>

<ul class="grid grid-cols-1 sm:grid-cols-2 gap-12 max-w-4xl">

{categories.map(cat => (

<li>

<a href={`/${cat.slug}`} class="category-card group block p-10 text-center">

<div class="icon-box mb-6 mx-auto">

{categoryIcons[cat.slug] ?? "⚡"}

</div>

<h3 class="text-2xl font-semibold text-white mb-2">

{cat.name}

</h3>

<p class="text-sm text-slate-400">

Discover tools for {cat.name.toLowerCase()}

</p>

</a>

</li>

))}

</ul>

</div>

</section>

</Layout>