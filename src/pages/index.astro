---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

type Category = {
  _id: string;
  name: string;
  slug: string;
};

const categoryIcons: Record<string, string> = {
  "photo-editing": "🖼️",
  "video-editing": "🎬",
  "audio-editing": "🎧",
  "thumbnail-tools": "🧩",
  "ai-tools": "🤖",
};

const categories: Category[] = await sanityClient.fetch(`
  *[_type == "category"]{
    _id,
    name,
    "slug": slug.current
  }
`);
---

<Layout>

  <!-- HERO -->
  <section class="relative mb-32">

    <!-- Cinematic light -->
    <div class="ai-light top-[-300px] left-[-200px]"></div>

    <div class="max-w-3xl relative z-10">

      <h1 class="text-6xl font-bold leading-tight text-white">
        ZapFrame
        <span class="gradient-text">Tools</span>
      </h1>

      <p class="mt-4 text-2xl font-semibold text-sky-400">
        Stop searching. Just use ZapFrame.
      </p>

      <p class="mt-6 text-slate-300 text-lg max-w-xl">
        A curated platform to discover the best free tools for content creators and video editors.
      </p>

      <div class="mt-10">
        <a
          href="#categories"
          class="btn-ai"
        >
          Explore Categories
        </a>
      </div>

    </div>

  </section>

  <!-- CATEGORIES -->
  <section id="categories">

    <h2 class="text-4xl font-bold mb-3 text-white">
      Categories
    </h2>

    <p class="text-slate-300 mb-12 max-w-2xl">
      Discover the best tools organized by category
    </p>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

      {categories.map(cat => (

        <li>

          <a
            href={`/${cat.slug}`}
            class="
              card-ai
              block
              rounded-xl
              p-8
              h-full
              text-center
              group
            "
          >

            <!-- icon -->
            <div class="
              w-16 h-16
              mb-6
              rounded-xl
              bg-white/5
              flex
              items-center
              justify-center
              mx-auto
              text-2xl
              group-hover:scale-110
              transition
            ">
              {categoryIcons[cat.slug] ?? "⚡"}
            </div>

            <h3 class="text-xl font-semibold mb-2 text-white">
              {cat.name}
            </h3>

            <p class="text-sm text-slate-400">
              Best tools for {cat.name.toLowerCase()}
            </p>

          </a>

        </li>

      ))}

    </ul>

  </section>

</Layout>