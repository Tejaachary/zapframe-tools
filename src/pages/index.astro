---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

type Category = {
  _id: string;
  name: string;
  slug: string;
};

const categories: Category[] = await sanityClient.fetch(`
  *[_type == "category"] {
    _id,
    name,
    "slug": slug.current
  }
`);
---

<Layout>
  <!-- HERO -->
  <section class="mb-32">
    <h1 class="text-6xl font-bold leading-tight mb-6">
      Stop searching.<br />
      <span class="gradient-text">Just use ZapFrame.</span>
    </h1>

    <p class="text-gray-600 max-w-2xl text-lg">
      A curated list of the best free and useful tools for content creators,
      video editors, and beginners.
    </p>
  </section>

  <!-- CATEGORIES -->
  <section>
    <h2 class="text-2xl font-semibold mb-10">
      Categories
    </h2>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {categories.map((cat) => (
        <li>
          <a
            href={`/${cat.slug}`}
            class="glass card-hover block rounded-2xl p-8"
          >
            <h3 class="text-xl font-semibold mb-2">
              {cat.name}
            </h3>

            <p class="text-sm text-gray-500">
              Best tools for {cat.name.toLowerCase()}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
