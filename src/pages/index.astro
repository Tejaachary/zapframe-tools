---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

/* =============================
   Types
============================= */
type Category = {
  _id: string;
  name: string;
  slug: string;
};

type Tool = {
  name: string;
  url: string;
};

/* =============================
   Fetch categories
============================= */
const categories: Category[] = await sanityClient.fetch(`
  *[_type == "category"] {
    _id,
    name,
    "slug": slug.current
  }
`);

/* =============================
   Fetch tools for search
============================= */
const tools: Tool[] = await sanityClient.fetch(`
  *[_type == "tool"]{
    name,
    url
  }
`);
---

<Layout>
  <!-- ================= HERO ================= -->
  <section class="mb-32">

    <!-- HEADLINE + SEARCH -->
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8 mb-6">
      
      <!-- HEADLINE -->
      <h1 class="text-6xl font-bold leading-tight">
        Stop searching.<br />
        <span class="gradient-text">Just use ZapFrame.</span>
      </h1>

      <!-- SEARCH -->
      <div class="relative w-full lg:w-[420px]">
        <input
          id="searchInput"
          type="text"
          placeholder="Search tools (CapCut, Canva, DaVinci…) "
          autocomplete="off"
          class="w-full rounded-2xl border border-gray-200 px-12 py-4 text-sm shadow-sm focus:outline-none focus:ring-0 focus:shadow-[0_0_0_3px_rgba(66,133,244,0.25)]"
        />

        <!-- RAINBOW MAGNIFIER -->
        <span
          class="absolute left-4 top-1/2 -translate-y-1/2 text-xl font-bold rainbow-icon pointer-events-none"
          aria-hidden="true"
        >
          🔍
        </span>

        <!-- SEARCH RESULTS -->
        <ul
          id="results"
          class="absolute z-10 mt-3 w-full rounded-2xl bg-white shadow-lg hidden overflow-hidden"
        ></ul>
      </div>
    </div>

    <!-- SUBTEXT -->
    <p class="text-gray-600 max-w-2xl text-lg">
      A curated list of the best free and useful tools for content creators,
      video editors, and beginners.
    </p>
  </section>

  <!-- ================= CATEGORIES ================= -->
  <section>
    <h2 class="text-2xl font-semibold mb-10">
      Categories
    </h2>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {categories.map((cat) => (
        <li>
          <a
            href={`/${cat.slug}`}
            class="glass card-hover block rounded-2xl p-8"
          >
            <h3 class="text-xl font-semibold mb-2">
              {cat.name}
            </h3>
            <p class="text-sm text-gray-500">
              Best tools for {cat.name.toLowerCase()}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ================= SEARCH DATA ================= -->
  <script id="tools-data" type="application/json">
    {JSON.stringify(tools)}
  </script>

  <!-- ================= SEARCH SCRIPT ================= -->
  <!-- Astro-safe, zero TS errors -->
  <script is:inline>
    const tools = JSON.parse(
      document.getElementById("tools-data")?.textContent || "[]"
    );

    const input = document.getElementById("searchInput");
    const results = document.getElementById("results");

    if (!input || !results) return;

    function highlightMatch(text, query) {
      const regex = new RegExp(`(${query})`, "ig");
      return text.replace(regex, "<strong>$1</strong>");
    }

    input.addEventListener("input", () => {
      const value = input.value.toLowerCase().trim();
      results.innerHTML = "";

      if (!value) {
        results.classList.add("hidden");
        return;
      }

      // Play Store style ordering
      const startsWith = tools.filter(tool =>
        tool.name.toLowerCase().startsWith(value)
      );

      const contains = tools.filter(
        tool =>
          !tool.name.toLowerCase().startsWith(value) &&
          tool.name.toLowerCase().includes(value)
      );

      const matches = [...startsWith, ...contains].slice(0, 8);

      if (matches.length === 0) {
        results.innerHTML = `
          <li class="px-4 py-3 text-sm text-gray-500">
            No tools found
          </li>
        `;
      } else {
        matches.forEach(tool => {
          const li = document.createElement("li");
          li.innerHTML = `
            <a
              href="${tool.url}"
              target="_blank"
              rel="noopener noreferrer"
              class="block px-4 py-3 text-sm hover:bg-gray-100"
            >
              🔗 ${highlightMatch(tool.name, value)}
            </a>
          `;
          results.appendChild(li);
        });
      }

      results.classList.remove("hidden");
    });
  </script>

  <!-- ================= STYLES ================= -->
  <style>
    .rainbow-icon {
      background: linear-gradient(
        90deg,
        #4285f4,
        #34a853,
        #fbbc05,
        #ea4335,
        #8e24aa,
        #4285f4
      );
      background-size: 300% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      animation: rainbow-move 6s linear infinite;
    }

    @keyframes rainbow-move {
      0% {
        background-position: 0% 50%;
      }
      100% {
        background-position: 300% 50%;
      }
    }
  </style>
</Layout>
