---
// src/pages/index.astro — FINAL (NO SEARCH)
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

type Category = {
  _id: string;
  name: string;
  slug: string;
};

const categories: Category[] = await sanityClient.fetch(`
  *[_type == "category"]{
    _id,
    name,
    "slug": slug.current
  }
`);
---

<Layout>
  <!-- HERO -->
  <section class="mb-28">
    <div class="max-w-2xl">
      <h1 class="text-6xl font-bold leading-tight text-white">
        Stop searching.<br />
        <span class="gradient-text">Just use ZapFrame.</span>
      </h1>

      <p class="mt-6 text-slate-300 text-lg">
        A curated list of the best free tools for creators.
      </p>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section>
    <h2 class="text-4xl font-bold mb-3 text-white">
      Categories
    </h2>

    <p class="text-slate-300 mb-10 max-w-2xl">
      Discover the best tools organized by category
    </p>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {categories.map(cat => (
        <li>
          <a
            href={`/${cat.slug}`}
            class="
              glass
              block
              rounded-xl
              p-6
              h-full
              transition
              hover:-translate-y-1
            "
          >
            <div class="w-14 h-14 mb-5 rounded-xl bg-pink-500/20 flex items-center justify-center mx-auto">
              <span class="text-xl">🎬</span>
            </div>

            <h3 class="text-xl font-semibold mb-3 text-white text-center">
              {cat.name}
            </h3>

            <p class="text-sm text-slate-300 text-center">
              Best tools for {cat.name.toLowerCase()}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
