---
// src/pages/[slug].astro — FINAL CLEAN VERSION (UPDATED)
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

type Tool = {
  _id: string;
  name: string;
  slug: string;
  description: string;
  url: string;
  isFree: boolean;
  platform: "mobile" | "pc" | "both";
  featured?: boolean;
  logoUrl?: string;
  rating?: number;
  downloads?: string;
};

export async function getStaticPaths() {
  const cats: { slug: string }[] = await sanityClient.fetch(`
    *[_type == "category"]{ "slug": slug.current }
  `);
  return cats.map(c => ({ params: { slug: c.slug } }));
}

const slug = Astro.params.slug as string;

const tools: Tool[] = await sanityClient.fetch(
  `*[_type=="tool" && category->slug.current==$slug]{
    _id,
    name,
    "slug": slug.current,
    description,
    url,
    isFree,
    platform,
    featured,
    "logoUrl": logo.asset->url,
    rating,
    downloads
  }`,
  { slug }
);

const featuredTools = tools.filter(t => t.featured);
const regularTools = tools.filter(t => !t.featured);

const mobileTools = featuredTools
  .filter(t => t.platform === "mobile" || t.platform === "both")
  .concat(regularTools.filter(t => t.platform === "mobile" || t.platform === "both"));

const pcTools = featuredTools
  .filter(t => t.platform === "pc" || t.platform === "both")
  .concat(regularTools.filter(t => t.platform === "pc" || t.platform === "both"));

const titleWords = slug
  .split("-")
  .map(w => w[0].toUpperCase() + w.slice(1))
  .join(" ");
---

<Layout title={titleWords}>

  <!-- PAGE TITLE -->
  <h1 class="text-5xl font-bold mb-10 text-white flex items-center gap-3">
    🎬 <span class="gradient-text">{titleWords}</span>
  </h1>

  {tools.length === 0 && (
    <div class="glass rounded-xl p-10 text-center">
      <p class="text-slate-300">No tools in this category yet</p>
    </div>
  )}

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

    <!-- 📱 MOBILE TOOLS -->
    <section>
      <h2 class="text-2xl font-semibold mb-5 text-white">
        📱 Mobile
        {mobileTools.length === 0 && (
          <span class="ml-2 text-sm text-slate-300">(Coming soon)</span>
        )}
      </h2>

      {mobileTools.length > 0 ? (
        <ul class="space-y-5">
          {mobileTools.map(tool => (
            <li
              id={tool.slug}
              class="glass p-5 rounded-xl transition-all duration-300 hover:-translate-y-1 hover:perspective-1000"
            >
              {tool.featured && (
                <div class="mb-2 text-xs font-semibold text-pink-300">
                  🌸 Recommended
                </div>
              )}

              {tool.logoUrl && (
                <img
                  src={tool.logoUrl}
                  alt={`${tool.name} logo`}
                  class="w-12 h-12 mb-4 object-contain rounded-lg"
                  loading="lazy"
                />
              )}

              <h3 class="font-semibold text-lg text-white mb-2">
                {tool.name}
              </h3>

              <p class="text-sm text-slate-300 mb-4">
                {tool.description}
              </p>

              {tool.rating && (
                <div class="text-xs text-slate-400 mb-2">
                  ⭐ {tool.rating}/5
                </div>
              )}
              
              {tool.downloads && (
                <div class="text-xs text-slate-400 mb-4">
                  📥 {tool.downloads}
                </div>
              )}

              <div class="flex items-center gap-3 flex-wrap">
                <a
                  href={tool.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 text-sm rounded-lg bg-pink-500/80 hover:bg-pink-500 text-white transition-all duration-300"
                >
                  Download
                </a>

                {tool.isFree && (
                  <span class="text-xs text-pink-200 border border-white/20 px-3 py-1 rounded-full">
                    Free
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <div class="glass p-10 text-center">
          <p class="text-slate-300">No mobile tools yet</p>
        </div>
      )}
    </section>

    <!-- 💻 PC TOOLS -->
    <section>
      <h2 class="text-2xl font-semibold mb-5 text-white">
        💻 PC
        {pcTools.length === 0 && (
          <span class="ml-2 text-sm text-slate-300">(Coming soon)</span>
        )}
      </h2>

      {pcTools.length > 0 ? (
        <ul class="space-y-5">
          {pcTools.map(tool => (
            <li
              id={tool.slug}
              class="glass p-5 rounded-xl transition-all duration-300 hover:-translate-y-1 hover:perspective-1000"
            >
              {tool.featured && (
                <div class="mb-2 text-xs font-semibold text-pink-300">
                  🌸 Recommended
                </div>
              )}

              {tool.logoUrl && (
                <img
                  src={tool.logoUrl}
                  alt={`${tool.name} logo`}
                  class="w-12 h-12 mb-4 object-contain rounded-lg"
                  loading="lazy"
                />
              )}

              <h3 class="font-semibold text-lg text-white mb-2">
                {tool.name}
              </h3>

              <p class="text-sm text-slate-300 mb-4">
                {tool.description}
              </p>

              {tool.rating && (
                <div class="text-xs text-slate-400 mb-2">
                  ⭐ {tool.rating}/5
                </div>
              )}
              
              {tool.downloads && (
                <div class="text-xs text-slate-400 mb-4">
                  📥 {tool.downloads}
                </div>
              )}

              <div class="flex items-center gap-3 flex-wrap">
                <a
                  href={tool.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 text-sm rounded-lg bg-pink-500/80 hover:bg-pink-500 text-white transition-all duration-300"
                >
                  Download
                </a>

                {tool.isFree && (
                  <span class="text-xs text-pink-200 border border-white/20 px-3 py-1 rounded-full">
                    Free
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
      ) : (
        <div class="glass p-10 text-center">
          <p class="text-slate-300">No PC tools yet</p>
        </div>
      )}
    </section>

  </div>
</Layout>
