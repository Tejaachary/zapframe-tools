---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

type Tool = {
  _id: string;
  name: string;
  slug: string;
  description: string;
  url: string;
  isFree: boolean;
  platform: "mobile" | "pc" | "both";
  featured?: boolean;
  logoUrl?: string;
  rating?: number;
  downloads?: string;
};

export async function getStaticPaths() {
  const cats: { slug: string }[] = await sanityClient.fetch(`
    *[_type == "category"]{ "slug": slug.current }
  `);

  return cats.map(c => ({ params: { slug: c.slug } }));
}

const slug = Astro.params.slug as string;

const tools: Tool[] = await sanityClient.fetch(
`*[_type=="tool" && category->slug.current==$slug]{
  _id,
  name,
  "slug": slug.current,
  description,
  url,
  isFree,
  platform,
  featured,
  "logoUrl": logo.asset->url,
  rating,
  downloads
}`, { slug });

const featured = tools.filter(t => t.featured);
const regular = tools.filter(t => !t.featured);

const title = slug
  .split("-")
  .map(w => w[0].toUpperCase() + w.slice(1))
  .join(" ");
---

<Layout title={title}>

<!-- PAGE HEADER -->
<section class="mb-14">

  <h1 class="text-5xl font-bold flex items-center gap-3">
    🎬 <span class="gradient-text">{title}</span>
  </h1>

  <p class="text-slate-400 mt-3">
    Curated tools for {title.toLowerCase()}
  </p>

</section>


<!-- FEATURED TOOLS -->
{featured.length > 0 && (

<section class="mb-16">

<h2 class="text-2xl font-semibold mb-6 text-white">
🔥 Featured Tools
</h2>

<ul class="grid md:grid-cols-2 gap-6">

{featured.map(tool => (

<li class="glass p-6 rounded-xl border border-pink-500/20 hover:border-pink-500/40 transition">

{tool.logoUrl && (
<img
src={tool.logoUrl}
alt={tool.name}
class="w-14 h-14 mb-4 rounded-lg object-contain"
/>
)}

<h3 class="text-xl font-semibold mb-2">
{tool.name}
</h3>

<p class="text-slate-300 text-sm mb-4">
{tool.description}
</p>

<div class="flex items-center gap-4 text-xs text-slate-400 mb-4">

{tool.rating && <span>⭐ {tool.rating}/5</span>}
{tool.downloads && <span>📥 {tool.downloads}</span>}
<span>💻 {tool.platform}</span>

</div>

<a
href={tool.url}
target="_blank"
rel="noopener noreferrer"
class="btn-ai text-sm"
>
Visit Tool
</a>

</li>

))}

</ul>

</section>

)}


<!-- ALL TOOLS -->
<section>

<h2 class="text-2xl font-semibold mb-6 text-white">
All Tools
</h2>

{regular.length === 0 ? (

<div class="glass p-10 text-center">
<p class="text-slate-300">
No tools in this category yet
</p>
</div>

) : (

<ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">

{regular.map(tool => (

<li class="glass p-5 rounded-xl hover:-translate-y-1 transition">

{tool.logoUrl && (
<img
src={tool.logoUrl}
alt={tool.name}
class="w-12 h-12 mb-4 object-contain rounded"
/>
)}

<h3 class="font-semibold mb-2">
{tool.name}
</h3>

<p class="text-sm text-slate-400 mb-4">
{tool.description}
</p>

<div class="flex items-center justify-between">

<a
href={tool.url}
target="_blank"
rel="noopener noreferrer"
class="text-sm text-pink-400 hover:text-pink-300"
>
Open →
</a>

{tool.isFree && (
<span class="text-xs border border-white/20 px-2 py-1 rounded">
Free
</span>
)}

</div>

</li>

))}

</ul>

)}

</section>

</Layout>