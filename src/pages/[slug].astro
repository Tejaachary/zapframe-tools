---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

/* Generate static pages for each category */
export async function getStaticPaths() {
  const categories: { slug: string }[] = await sanityClient.fetch(`
    *[_type == "category"] {
      "slug": slug.current
    }
  `);

  return categories.map((cat) => ({
    params: { slug: cat.slug },
  }));
}

/* Safely get slug param */
const slug = Astro.params.slug as string;

/* Fetch tools for the category */
type Tool = {
  _id: string;
  name: string;
  description: string;
  url: string;
  isFree: boolean;
};

const tools: Tool[] = await sanityClient.fetch(
  `
  *[_type == "tool" && category->slug.current == $slug] {
    _id,
    name,
    description,
    url,
    isFree
  }
  `,
  { slug }
);

/* Convert slug to title */
const pageTitle = slug
  .split("-")
  .map(word => word[0].toUpperCase() + word.slice(1))
  .join(" ");
---

<Layout>
  <main class="max-w-4xl mx-auto py-16 px-4">
    <h1 class="text-3xl font-bold mb-10">
      {pageTitle}
    </h1>

    {tools.length === 0 ? (
      <p class="text-gray-400">
        No tools added yet.
      </p>
    ) : (
      <ul class="grid gap-6">
        {tools.map((tool) => (
          <li class="border border-gray-800 p-5 rounded-lg hover:border-gray-600 transition">
            <h2 class="text-xl font-semibold">
              {tool.name}
            </h2>

            <p class="text-gray-400 mt-2">
              {tool.description}
            </p>

            <div class="mt-3 flex items-center gap-4">
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-400 hover:underline"
              >
                Visit tool →
              </a>

              {tool.isFree && (
                <span class="text-xs bg-green-600/20 text-green-400 px-2 py-1 rounded">
                  Free
                </span>
              )}
            </div>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>
