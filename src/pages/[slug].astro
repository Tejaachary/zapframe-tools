---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

/* -----------------------------
   Types
------------------------------ */
type CategorySlug = {
  slug: string;
};

type Tool = {
  _id: string;
  name: string;
  description: string;
  url: string;
  isFree: boolean;
};

/* -----------------------------
   Static Paths
------------------------------ */
export async function getStaticPaths() {
  const categories: CategorySlug[] = await sanityClient.fetch(`
    *[_type == "category"] {
      "slug": slug.current
    }
  `);

  return categories.map((cat: CategorySlug) => ({
    params: { slug: cat.slug },
  }));
}

/* -----------------------------
   Page Params
------------------------------ */
const slug = Astro.params.slug as string;

/* -----------------------------
   Fetch Tools
------------------------------ */
const tools: Tool[] = await sanityClient.fetch(
  `
  *[_type == "tool" && category->slug.current == $slug] {
    _id,
    name,
    description,
    url,
    isFree
  }
  `,
  { slug }
);

/* -----------------------------
   Title Formatting
------------------------------ */
const title = slug
  .split("-")
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(" ");
---

<Layout>
  <h1 class="text-5xl font-bold mb-16">
    <span class="gradient-text">{title}</span>
  </h1>

  {tools.length === 0 ? (
    <p class="text-gray-500">
      Tools are being curated. Check back soon.
    </p>
  ) : (
    <ul class="grid gap-10">
      {tools.map((tool: Tool) => (
        <li class="glass card-hover rounded-2xl p-6">
          <div class="flex justify-between items-start">
            <h2 class="text-lg font-semibold">
              {tool.name}
            </h2>

            {tool.isFree && (
              <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">
                Free
              </span>
            )}
          </div>

          <p class="text-gray-500 mt-3 text-sm">
            {tool.description}
          </p>

          <a
            href={tool.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-4 text-blue-600 hover:underline text-sm"
          >
            Visit tool →
          </a>
        </li>
      ))}
    </ul>
  )}
</Layout>
