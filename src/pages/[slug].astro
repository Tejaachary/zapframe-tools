---
import Layout from "../layouts/Layout.astro";
import { sanityClient } from "../lib/sanity";

type Tool = {
  _id: string;
  name: string;
  slug: string;
  description: string;
  url: string;
  isFree: boolean;
  platform: "mobile" | "pc" | "both";
  featured?: boolean;
  logoUrl?: string;
};

export async function getStaticPaths() {
  const cats: { slug: string }[] = await sanityClient.fetch(`
    *[_type == "category"]{ "slug": slug.current }
  `);

  return cats.map(c => ({ params: { slug: c.slug } }));
}

const slug = Astro.params.slug as string;

const tools: Tool[] = await sanityClient.fetch(
  `
  *[_type=="tool" && category->slug.current==$slug]{
    _id,
    name,
    "slug": slug.current,
    description,
    url,
    isFree,
    platform,
    featured,
    "logoUrl": logo.asset->url
  }
`,
  { slug }
);

const mobileTools = tools.filter(
  (t: Tool) => t.platform === "mobile" || t.platform === "both"
);
const pcTools = tools.filter(
  (t: Tool) => t.platform === "pc" || t.platform === "both"
);

const title = slug
  .split("-")
  .map((w: string) => w[0].toUpperCase() + w.slice(1))
  .join(" ");
---

<Layout>
  <h1 class="text-5xl font-bold mb-14 flex items-center gap-3">
    🎬 <span class="gradient-text">{title}</span>
  </h1>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-14">

    <!-- MOBILE -->
    <section>
      <h2 class="text-2xl font-semibold mb-6">📱 Mobile</h2>
      <ul class="space-y-6">
        {mobileTools.map((tool: Tool) => (
          <li id={tool.slug} class="glass rounded-2xl p-6 scroll-mt-32">
            <h3 class="font-semibold">{tool.name}</h3>
            <p class="text-sm text-gray-500">{tool.description}</p>
          </li>
        ))}
      </ul>
    </section>

    <!-- PC -->
    <section>
      <h2 class="text-2xl font-semibold mb-6">💻 PC</h2>
      <ul class="space-y-6">
        {pcTools.map((tool: Tool) => (
          <li id={tool.slug} class="glass rounded-2xl p-6 scroll-mt-32">
            <h3 class="font-semibold">{tool.name}</h3>
            <p class="text-sm text-gray-500">{tool.description}</p>
          </li>
        ))}
      </ul>
    </section>

  </div>

  <!-- HIGHLIGHT -->
  <script is:inline>
    const id = location.hash.replace("#", "");
    if (id) {
      const el = document.getElementById(id);
      if (el) {
        el.scrollIntoView({ behavior: "smooth", block: "center" });
        el.classList.add("ring-2","ring-blue-400");
        setTimeout(() => {
          el.classList.remove("ring-2","ring-blue-400");
        }, 2500);
      }
    }
  </script>
</Layout>
