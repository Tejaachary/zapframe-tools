---
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>ZapFrame</title>
    <meta name="description" content="ZapFrame — curated tools for creators." />

    <!-- Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics (GA4) -->
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-9P26TYDJR2">
    </script>

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ window.dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-9P26TYDJR2');
    </script>
  </head>

  <body class="antialiased text-slate-100 font-[Inter]">

    <!-- HEADER -->
    <header class="glass border-b border-white/20">
      <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">

        <!-- LOGO -->
        <a href="/" class="flex items-center gap-2 leading-none">
          <span class="text-xl font-bold text-white translate-y-px">⚡</span>
          <span class="text-xl font-extrabold tracking-tight gradient-text">
            ZapFrame
          </span>
        </a>

        <span class="text-sm text-slate-200">
          Curated creator tools
        </span>
      </div>
    </header>

    <!-- PAGE CONTENT -->
    <main class="max-w-6xl mx-auto px-4 py-20">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="glass border-t border-white/20 mt-20">
      <div class="max-w-6xl mx-auto px-4 py-6 text-sm text-slate-200 flex justify-between">
        <span>© {new Date().getFullYear()} ZapFrame</span>
        <span>
          Built by <strong class="text-white">Teja Chary</strong>
        </span>
      </div>
    </footer>

  </body>
</html>
