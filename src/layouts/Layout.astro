---
import "../styles/global.css";

const {
  title = "ZapFrame Tools – Best Free Tools for Creators",
  description = "Discover the best free tools for content creators, video editors, and AI builders.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href="https://zapframe-tools.netlify.app/" />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://zapframe-tools.netlify.app/" />
<meta property="og:image" content="/og-image.png" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content="/og-image.png" />

<!-- Favicon -->
<link rel="icon" type="image/png" href="/favicon.png" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<link
href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
rel="stylesheet"
/>

<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-9P26TYDJR2"></script>

<script is:inline>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-9P26TYDJR2');
</script>

</head>

<body class="antialiased text-slate-100 font-[Inter]">

<!-- HEADER -->
<header class="glass border-b border-white/10 sticky top-0 z-50 backdrop-blur-xl">

<div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">

<!-- LOGO -->
<a href="/" class="flex items-center gap-2">

<span class="text-xl">⚡</span>

<span class="font-extrabold gradient-text text-xl">
ZapFrame
</span>

</a>

<!-- NAV -->
<nav class="flex items-center gap-6 text-sm text-slate-300">

<a href="/" class="hover:text-white transition">
Home
</a>

<a href="/#categories" class="hover:text-white transition">
Categories
</a>

<a href="/ai-tools" class="hover:text-white transition">
AI Tools
</a>

</nav>

</div>

</header>


<!-- PAGE -->
<main class="max-w-6xl mx-auto px-4 py-20 relative">

<!-- subtle background glow -->
<div class="hero-light top-[-200px] left-[30%] opacity-40"></div>

<slot />

</main>


<!-- FOOTER -->
<footer class="glass border-t border-white/10 mt-20">

<div class="max-w-6xl mx-auto px-4 py-8 text-sm text-slate-300 flex flex-col md:flex-row justify-between gap-4">

<span>
© {new Date().getFullYear()} ZapFrame
</span>

<span>
Built by <strong class="text-white">Teja Chary</strong>
</span>

</div>

</footer>

</body>
</html>